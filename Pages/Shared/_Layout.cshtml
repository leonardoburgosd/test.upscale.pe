<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - test.upscale.app</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/custom-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/test.upscale.app.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Navbar -->
    <div class="top-navbar">
        <div class="navbar-left">
            <button class="toggle-sidebar-btn" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <div class="navbar-brand-text">Test Interview APP</div>
        </div>
        <div class="navbar-right">
            <i class="bi bi-question-circle" title="Ayuda"></i>
            <i class="bi bi-bell" title="Notificaciones"></i>
            <i class="bi bi-person-circle" title="Perfil"></i>
            <span class="user-name">@(ViewData["FullUserName"] ?? "Usuario")</span>
        </div>
    </div>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <!-- Sidebar Items -->
            <a href="#" class="sidebar-item active" title="Inicio">
                <i class="bi bi-house-door"></i>
                <span class="sidebar-item-text">Inicio</span>
            </a>
            <a href="#" class="sidebar-item" title="Registro">
                <i class="bi bi-building"></i>
                <span class="sidebar-item-text">Registro</span>
            </a>
            <a href="#" class="sidebar-item" title="Bloquear">
                <i class="bi bi-file-earmark-plus"></i>
                <span class="sidebar-item-text">Bloquear</span>
            </a>
            <a href="#" class="sidebar-item" title="Búsqueda">
                <i class="bi bi-search"></i>
                <span class="sidebar-item-text">Búsqueda</span>
            </a>
            <a href="/login" class="sidebar-item" title="Cerrar sesión" style="margin-top: auto; border-top: 1px solid #dee2e6;">
                <i class="bi bi-box-arrow-right"></i>
                <span class="sidebar-item-text">Cerrar sesión</span>
            </a>
        </div>

        <!-- Content Area -->
        <div class="content-area">
            <div class="page-content">
                @RenderBody()
            </div>

            <!-- Footer -->
            <div class="footer-bar">
                <img src="https://guias.servicios.gob.pe/static/archivos/gb1.svg" alt="Gob.pe Logo" />
                <span>Presidencia del Consejo de Ministros - Centro Nacional Requerimientos Especiales</span>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('expanded');
        }

        // Close sidebar on link click (mobile)
        document.querySelectorAll('.sidebar-item').forEach(item => {
            item.addEventListener('click', function() {
                if (window.innerWidth <= 768) {
                    const sidebar = document.getElementById('sidebar');
                    sidebar.classList.remove('expanded');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
