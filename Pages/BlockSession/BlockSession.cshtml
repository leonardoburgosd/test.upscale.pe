@page "/block"
@model BlockSessionModel
@{
    ViewData["Title"] = "Sesión Bloqueada";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/custom-styles.css" />
</head>
<body>
    <div class="page-wrapper">
        <!-- Header Bar -->
        <div class="header-bar"></div>

        <!-- Main Content -->
        <div class="main-content">
            <div class="login-card block-card">
                <!-- Icon -->
                <div class="block-icon">
                    🔒
                </div>

                <!-- Divider -->
                <div class="divider-line"></div>

                <!-- Title -->
                <h1 class="login-title">Cuenta bloqueada temporalmente</h1>
                
                <p class="block-description">Haz extendido el número maximo de intentos fallidos (5). Por seguridad, tu cuenta ah sido bloqueada durante 15 minutos. Intenta nuevamente más tarde.</p>

                <!-- Action Button -->
                <a href="/" class="btn-gobpe-primary mt-3">
                    Volver al Inicio
                </a>
            </div>
        </div>

        <!-- Footer Bar -->
        <div class="footer-bar">
            <img src="https://guias.servicios.gob.pe/static/archivos/gb1.svg" alt="Gob.pe Logo" />
            <span>Presidencia del Consejo de Ministros - Centro Nacional Requerimientos Especiales</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
